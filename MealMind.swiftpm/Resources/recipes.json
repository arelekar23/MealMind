    "name": "Rava Upma",
    "cuisine": "Maharashtrian",
    "category": "breakfast",
    "difficulty": "easy",
    "prepTime": 5,
    "cookTime": 15,
    "servings": 2,
    "calories": 280,
    "tags": ["vegetarian", "quick", "budget", "one-pot"],
    "ingredients": [
      { "name": "rava", "quantity": 1, "unit": "cup", "category": "pantry", "type": "bulk" },
      { "name": "onion", "quantity": 1, "unit": "medium", "category": "vegetable", "type": "countable" },
      { "name": "green chili", "quantity": 2, "unit": "piece", "category": "vegetable", "type": "countable" },
      { "name": "mustard seeds", "quantity": 0.5, "unit": "tsp", "category": "spice", "type": "bulk" },
      { "name": "urad dal", "quantity": 1, "unit": "tsp", "category": "pantry", "type": "bulk" },
      { "name": "chana dal", "quantity": 1, "unit": "tsp", "category": "pantry", "type": "bulk" },
      { "name": "curry leaves", "quantity": 8, "unit": "piece", "category": "herb", "type": "countable" },
      { "name": "oil", "quantity": 2, "unit": "tbsp", "category": "condiment", "type": "bulk" },
      { "name": "water", "quantity": 2.5, "unit": "cup", "category": "pantry", "type": "bulk" },
      { "name": "salt", "quantity": 1, "unit": "tsp", "category": "pantry", "type": "bulk" },
      { "name": "lemon", "quantity": 0.5, "unit": "piece", "category": "fruit", "type": "countable" },
      { "name": "coriander leaves", "quantity": 2, "unit": "tbsp", "category": "herb", "type": "bulk" }
    ],
    "steps": [
      "Dry roast rava on medium heat until light golden and fragrant. Set aside.",
      "Heat oil in a pan. Add mustard seeds and let them splutter.",
      "Add urad dal and chana dal. Fry until golden.",
      "Add curry leaves, green chilies, and chopped onion. Sauté until onion turns translucent.",
      "Add water and salt. Bring to a boil.",
      "Lower the flame and slowly add roasted rava while stirring continuously to avoid lumps.",
      "Cover and cook on low heat for 3-4 minutes until water is absorbed.",
      "Squeeze lemon juice, garnish with coriander leaves and serve hot."
    ],
    "tips": "Roasting the rava well is the key to non-sticky upma. Always add rava to boiling water, not the other way around.",
