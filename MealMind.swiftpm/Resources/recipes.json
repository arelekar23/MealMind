      { "name": "sugar", "quantity": 1, "unit": "tsp", "category": "pantry", "type": "bulk" },
      { "name": "curry leaves", "quantity": 8, "unit": "piece", "category": "herb", "type": "countable" },
      { "name": "peanuts", "quantity": 2, "unit": "tbsp", "category": "pantry", "type": "bulk" },
      { "name": "oil", "quantity": 2, "unit": "tbsp", "category": "condiment", "type": "bulk" },
      { "name": "salt", "quantity": 0.5, "unit": "tsp", "category": "pantry", "type": "bulk" },
      { "name": "lemon", "quantity": 0.5, "unit": "piece", "category": "fruit", "type": "countable" },
      { "name": "coriander leaves", "quantity": 2, "unit": "tbsp", "category": "herb", "type": "bulk" }
    ],
    "steps": [
      "Rinse poha in water, drain immediately, and set aside. Do not soak.",
      "Add turmeric, salt, and sugar to the drained poha. Mix gently.",
      "Heat oil in a pan. Add mustard seeds and let them splutter.",
      "Add peanuts and fry until light golden.",
      "Add curry leaves, green chilies, and chopped onions. Sauté until onions turn soft.",
      "Lower the flame and add the poha. Mix gently so it doesn't break.",
      "Cover and cook on low heat for 2 minutes.",
      "Squeeze lemon juice, garnish with coriander leaves and serve."
    ],
    "tips": "Never soak poha — just rinse and drain quickly. The moisture from rinsing is enough to soften it.",
