    "prepTime": 10,
    "cookTime": 15,
    "servings": 2,
    "calories": 200,
    "tags": ["vegetarian", "quick", "budget", "gluten-free"],
    "ingredients": [
      { "name": "potato", "quantity": 3, "unit": "medium", "category": "vegetable", "type": "countable" },
      { "name": "onion", "quantity": 1, "unit": "medium", "category": "vegetable", "type": "countable" },
      { "name": "green chili", "quantity": 2, "unit": "piece", "category": "vegetable", "type": "countable" },
      { "name": "mustard seeds", "quantity": 0.5, "unit": "tsp", "category": "spice", "type": "bulk" },
      { "name": "turmeric", "quantity": 0.25, "unit": "tsp", "category": "spice", "type": "bulk" },
      { "name": "red chili powder", "quantity": 0.5, "unit": "tsp", "category": "spice", "type": "bulk" },
      { "name": "curry leaves", "quantity": 8, "unit": "piece", "category": "herb", "type": "countable" },
      { "name": "oil", "quantity": 2, "unit": "tbsp", "category": "condiment", "type": "bulk" },
      { "name": "salt", "quantity": 0.5, "unit": "tsp", "category": "pantry", "type": "bulk" },
      { "name": "coriander leaves", "quantity": 2, "unit": "tbsp", "category": "herb", "type": "bulk" }
    ],
    "steps": [
      "Peel potatoes and slice them into very thin rounds using a slicer or sharp knife.",
      "Heat oil in a flat tava. Add mustard seeds and let them splutter.",
      "Add curry leaves and green chilies. Sauté for 10 seconds.",
      "Add sliced onion and cook until slightly soft.",
      "Add turmeric, red chili powder, and salt. Mix well.",
      "Spread the thin potato slices in a single layer on the tava. Let them cook undisturbed for 3-4 minutes until crispy on one side.",
      "Flip gently and cook the other side until golden and crispy.",
      "Garnish with coriander leaves and serve hot with poli."
